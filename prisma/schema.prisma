generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model borrow_requests {
  id           Int                     @id @default(autoincrement())
  item_id      Int
  user_id      Int
  status       borrow_requests_status? @default(pending)
  request_date DateTime?               @default(now()) @db.Timestamp(0)
  return_date  DateTime?               @db.Timestamp(0)
  items        items                   @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "borrow_requests_ibfk_1")
  users        users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "borrow_requests_ibfk_2")

  @@index([item_id], map: "idx_borrow_item")
  @@index([user_id], map: "idx_borrow_user")
}

model items {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(150)
  category        String?           @db.VarChar(100)
  quantity        Int?              @default(0)
  location        String?           @db.VarChar(150)
  image_url       String?           @db.VarChar(255)
  min_quantity    Int?              @default(1)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  borrow_requests borrow_requests[]
  transactions    transactions[]

  @@index([category], map: "idx_items_category")
}

model transactions {
  id       Int               @id @default(autoincrement())
  item_id  Int
  user_id  Int
  type     transactions_type
  quantity Int
  date     DateTime?         @default(now()) @db.Timestamp(0)
  items    items             @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "transactions_ibfk_1")
  users    users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "transactions_ibfk_2")

  @@index([item_id], map: "idx_transactions_item")
  @@index([user_id], map: "user_id")
}

model users {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  email           String            @unique(map: "email") @db.VarChar(150)
  password        String            @db.VarChar(255)
  role            users_role?       @default(staff)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  borrow_requests borrow_requests[]
  transactions    transactions[]
}

enum borrow_requests_status {
  pending
  approved
  rejected
  returned
}

enum transactions_type {
  borrow
  return
  stock_in
  stock_out
}

enum users_role {
  admin
  staff
}
